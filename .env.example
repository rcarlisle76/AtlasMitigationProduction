# Sanity CMS Configuration
# Get these values from https://sanity.io/manage after creating a project

# Your Sanity project ID (found in project settings)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id

# Dataset name (usually "production")
NEXT_PUBLIC_SANITY_DATASET=production

# API version (use current date format)
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: Sanity API token for authenticated requests (for previews/drafts)
# SANITY_API_TOKEN=your-api-token
