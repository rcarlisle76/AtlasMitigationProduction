# Sanity CMS
# Get these values from https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API token (required for seed scripts and write operations)
# Create one at: https://www.sanity.io/manage/project/<your-project-id>/settings/api
# Set permissions to "Editor"
# SANITY_API_TOKEN=your-token

# Site URL (for SEO)
NEXT_PUBLIC_SITE_URL=https://atlasmitigation.com
